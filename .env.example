# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars

# ── Payments ──────────────────────────────────────────────────────────────────
# Flutterwave: https://dashboard.flutterwave.com
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxx
FLUTTERWAVE_WEBHOOK_SECRET=your-webhook-secret

# Pesapal (alternative): https://developer.pesapal.com
# PESAPAL_CONSUMER_KEY=your-key
# PESAPAL_CONSUMER_SECRET=your-secret

PAYMENT_PROVIDER=flutterwave

# ── Bunny Stream ──────────────────────────────────────────────────────────────
# Get these from: https://dash.bunny.net/stream
BUNNY_STREAM_API_KEY=your-bunny-stream-api-key
BUNNY_STREAM_LIBRARY_ID=your-bunny-stream-library-id
# Example: skolr-videos
BUNNY_STREAM_PULL_ZONE=your-bunny-stream-pull-zone
# Optional: upload all new videos into a specific Bunny collection
# BUNNY_STREAM_COLLECTION_ID=your-bunny-collection-guid

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
